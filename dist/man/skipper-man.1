.nh
.TH "SKIPPER" "1" "Apr 2026" "dev" "Skipper Manual"

.SH NAME
skipper-man - generate man pages


.SH SYNOPSIS
\fBskipper man [directory] [flags]\fP


.SH DESCRIPTION
generate man pages


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for man


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	path to ssh config file, defaults to ~/.ssh/config


.SH EXAMPLE
.EX
skipper man ./dist/man
.EE


.SH SEE ALSO
\fBskipper(1)\fP
