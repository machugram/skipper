.TH "SKIPPER" "1" "Apr 2026" "dev" "Skipper Manual"

.SH NAME
skipper-completion - Generate the autocompletion script for the specified shell


.SH SYNOPSIS
\fBskipper completion [flags]\fP


.SH DESCRIPTION
Generate the autocompletion script for skipper for the specified shell.
See each sub-command's help for details on how to use the generated script.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB-c\fP, \fB--config\fP=""
	path to ssh config file, defaults to ~/.ssh/config


.SH SEE ALSO
\fBskipper(1)\fP, \fBskipper-completion-bash(1)\fP, \fBskipper-completion-fish(1)\fP, \fBskipper-completion-powershell(1)\fP, \fBskipper-completion-zsh(1)\fP
